<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= notFound ? 'Movie Not Found' : movie.title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main class="container pb-5">
    <% if (notFound) { %>
      <div class="text-center text-muted py-5">
        <h1>Movie not found</h1>
        <p>We couldn't find the movie you were looking for.</p>
        <a href="/movies" class="btn btn-primary">Back to all movies</a>
      </div>
    <% } else { %>

      <a href="/movies" class="d-inline-block mb-3 text-decoration-none">&larr; Back to all movies</a>

      <div class="card mb-5">
        <div class="row g-0">
          <div class="col-md-3">
            <img src="<%= movie.posterUrl %>" alt="<%= movie.title %> poster" class="img-fluid rounded-start h-100" style="object-fit: cover;" />
          </div>
          <div class="col-md-9">
            <div class="card-body">
              <h1 class="h3"><%= movie.title %> <span class="text-muted">(<%= movie.releaseYear %>)</span></h1>
              <p class="card-text"><%= movie.description %></p>
              <form action="/movies/<%= movie._id %>/delete" method="POST"
                    onsubmit="return confirm('Delete this movie and all its reviews?');">
                <button type="submit" class="btn btn-outline-danger">Delete Movie</button>
              </form>
            </div>
          </div>
        </div>
      </div>

      <section>
        <h2 class="h4 mb-3">Reviews (<%= reviews.length %>)</h2>

        <% if (reviews.length === 0) { %>
          <p class="text-muted">No reviews yet. Be the first to review this movie!</p>
        <% } else { %>
          <div class="list-group mb-4">
            <% reviews.forEach(function (review) { %>
              <%- include('partials/review-item', { review, movieId: movie._id }) %>
            <% }); %>
          </div>
        <% } %>

        <div class="card" style="max-width: 480px;">
          <div class="card-body">
            <h3 class="h5 card-title mb-3">Add a Review</h3>
            <form action="/movies/<%= movie._id %>/reviews" method="POST">
              <div class="mb-3">
                <label for="reviewerName" class="form-label">Your Name</label>
                <input type="text" id="reviewerName" name="reviewerName" class="form-control" required />
              </div>
              <div class="mb-3">
                <label for="rating" class="form-label">Rating (1-5)</label>
                <input type="number" id="rating" name="rating" class="form-control" min="1" max="5" required />
              </div>
              <div class="mb-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea id="comment" name="comment" class="form-control" rows="3" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary">Submit Review</button>
            </form>
          </div>
        </div>
      </section>

    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
