<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie rating </title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    
      <%- include('partials/navbar') %>

     <main class="container pb-5">
         <h1 class="mb-4">All movies </h1>

    <% if (movies.length === 0) { %>
      <p class="text-muted">No movies yet. Add the first one below!</p>
    <% } else { %>
      <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3 mb-5">
        <% movies.forEach(function (movie) { %>
          <%- include('partials/movie-card', { movie }) %>
        <% }); %>
      </div>
    <% } %>

    <!-- next section is to add a movie  -->
     <section class="card" style="max-width: 480px;">
      <div class="card-body">
        <h2 class="h5 card-title mb-3">Add a New Movie</h2>
        <form action="/movies" method="POST">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" id="title" name="title" class="form-control" required />
          </div>
          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea id="description" name="description" class="form-control" rows="3" required></textarea>
          </div>
          <div class="mb-3">
            <label for="releaseYear" class="form-label">Release Year</label>
            <input type="number" id="releaseYear" name="releaseYear" class="form-control" min="1888" max="2100" required />
          </div>
          <div class="mb-3">
            <label for="posterUrl" class="form-label">Poster Image URL</label>
            <input type="url" id="posterUrl" name="posterUrl" class="form-control" placeholder="https://..." required />
          </div>
          <button type="submit" class="btn btn-primary">Add Movie</button>
        </form>
      </div>
    </section>


     </main>

     <%- include('partials/footer') %>

</body>
</html>